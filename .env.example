# ============================================
# Beijing Street View Daily — Configuration
# ============================================
# Copy this file to .env.local and fill in your own credentials.
#   cp .env.example .env.local
#
# Get these credentials from:
#   - Feishu Open Platform (https://open.feishu.cn) — create an app
#   - Tencent Cloud COS (https://console.cloud.tencent.com/cos) — create a bucket
# ============================================

# --- Feishu Open API ---
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_BASE_ID=your_feishu_base_id_here
FEISHU_TABLE_ID=your_feishu_table_id_here
FEISHU_VIEW_ID=your_feishu_view_id_here

# --- Contact Form (separate Feishu table) ---
FEISHU_CONTACT_TABLE_ID=your_contact_table_id_here
FEISHU_CONTACT_BASE_ID=your_contact_base_id_here

# --- Tencent COS (for image cleanup script) ---
COS_SECRET_ID=your_cos_secret_id_here
COS_SECRET_KEY=your_cos_secret_key_here
COS_BUCKET=your_bucket_name_here
COS_REGION=ap-beijing
